{
    "compilerOptions": {
      "target": "ESNext",
      "module": "ESNext",
      "moduleResolution": "node",
      "outDir": "./dist",
      "baseUrl": "./src",
      "paths": {
        "@config/*": ["config/*"],
        "@services/*": ["services/*"],
        "@routes/*": ["routes/*"],
        "@utils/*": ["utils/*"]
      },
      "esModuleInterop": true,
      "skipLibCheck": true,
      "strict": true
    },
    "include": ["src/**/*"]
  }
  